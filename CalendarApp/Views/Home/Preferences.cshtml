@{
    ViewData["Title"] = "Change Settings";
}

<div class="col-12 col-md-6 mx-auto mb-4">
    <h6 class="text-body-secondary fw-bold mb-1">Select theme</h6>
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio1" value="light">
        <label class="form-check-label" for="inlineRadio1">Light</label>
    </div>
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio2" value="dark">
        <label class="form-check-label" for="inlineRadio2">Dark</label>
    </div>
    <div class="form-check form-check-inline mb-4">
        <input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio3" value="system">
        <label class="form-check-label" for="inlineRadio3">System default</label>
    </div>

    <h6 class="text-body-secondary fw-bold mb-1">Export data</h6>
    <button type="button" id="btn-export-json" class="btn btn-primary mb-4"><i class="bi bi-filetype-json"></i> Export JSON</button>
    <button type="button" id="btn-export-csv" class="btn btn-primary mb-4"><i class="bi bi-filetype-csv"></i> Export CSV</button>
            
    <h6 class="text-body-secondary fw-bold mb-1">Import data</h6>
    <div class="input-group mb-4">
        <input type="file" class="form-control" id="input-import-json" accept=".json, .csv, text/csv, application/json">
        <label class="input-group-text" for="input-import-json">Upload</label>
    </div>

    <h6 class="text-body-secondary fw-bold mb-1">Clear all data</h6>
    <button type="submit" data-bs-toggle="modal" data-bs-target="#deleteDataModal" class="btn btn-danger mb-4"><i class="bi bi-trash3-fill"></i> Delete</button>
</div>

<partial name="_DeleteData" />
<partial name="_ImportModal" />

@section Scripts {
    <script src="~/js/data-transfer.js" asp-append-version="true"></script>
}