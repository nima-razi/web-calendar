@{
    ViewData["Title"] = "Change Settings";
}

<div class="col-12 col-md-6 mx-auto mb-4">
    <div class="card bg-body-tertiary">
        <div class="card-header text-body-secondary"><h5>Appearance</h5></div>
        <div class="card-body">
            <h6 class="card-subtitle text-body-secondary mb-1">Select theme</h6>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio1" value="light">
                <label class="form-check-label" for="inlineRadio1">Light</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio2" value="dark">
                <label class="form-check-label" for="inlineRadio2">Dark</label>
            </div>
            <div class="form-check form-check-inline mb-4">
                <input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio3" value="system">
                <label class="form-check-label" for="inlineRadio3">System default</label>
            </div>

            <h6 class="card-subtitle text-body-secondary mb-1">Calendar View Density</h6>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="densityOption" id="densityComfortable" value="comfortable">
                <label class="form-check-label" for="densityComfortable">Comfortable</label>
            </div>
            <div class="form-check form-check-inline mb-4">
                <input class="form-check-input" type="radio" name="densityOption" id="densityCompact" value="compact">
                <label class="form-check-label" for="densityCompact">Compact</label>
            </div>

            <h6 class="card-subtitle text-body-secondary mb-1">First Day of Week</h6>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="" id="" value="">
                <label class="form-check-label" for="">Monday</label>
            </div>
            <div class="form-check form-check-inline mb-4">
                <input class="form-check-input" type="radio" name="" id="" value="">
                <label class="form-check-label" for="">Sunday</label>
            </div>
        </div>
    </div>    
</div>

<div class="col-12 col-md-6 mx-auto mb-4">
    <div class="card bg-body-tertiary">
        <div class="card-header text-body-secondary"><h5>Data Management</h5></div>
        <div class="card-body">
            <h6 class="card-subtitle text-body-secondary mb-1">Export data</h6>
            <button type="button" id="btn-export-json" class="btn btn-primary mb-4"><i class="bi bi-filetype-json"></i> Export JSON</button>
            <button type="button" id="btn-export-csv" class="btn btn-primary mb-4"><i class="bi bi-filetype-csv"></i> Export CSV</button>
            
            <h6 class="card-subtitle text-body-secondary mb-1">Import data</h6>
            <div class="input-group mb-4">
                <input type="file" class="form-control" id="input-import-json" accept=".json">
                <label class="input-group-text" for="input-import-json">Upload</label>
            </div>

            <h6 class="card-subtitle text-body-secondary mb-1">Clear all data</h6>
            <button type="submit" data-bs-toggle="modal" data-bs-target="#deleteDataModal" class="btn btn-danger mb-4"><i class="bi bi-trash3-fill"></i> Delete</button>
        </div>
    </div>
</div>

<div class="col-12 col-md-6 mx-auto mb-4">
    <div class="card bg-body-tertiary">
        <div class="card-header text-body-secondary"><h5>Notifications & Reminders</h5></div>
        <div class="card-body">
            <h6 class="card-subtitle text-body-secondary mb-1">Default event duration</h6>
            <input type="time" class="form-control w-auto mb-4" name="name" value="" />

            <h6 class="card-subtitle text-body-secondary mb-1">Default timezone</h6>
            <select class="form-select mb-4" aria-label="Default select example">
                <option selected>Open this select menu</option>
                <option value="1">One</option>
                <option value="2">Two</option>
                <option value="3">Three</option>
            </select>

            <h6 class="card-subtitle text-body-secondary mb-1">Default timezone</h6>
            <select class="form-select mb-4" aria-label="Default select example">
                <option selected>Open this select menu</option>
                <option value="1">One</option>
                <option value="2">Two</option>
                <option value="3">Three</option>
            </select>
        </div>
    </div>
</div>

<partial name="_DeleteData" />